{
  "name": "pamoja",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter frontend dev",
    "build": "pnpm --filter frontend build",
    "test": "pnpm --filter frontend test",
    "lint": "pnpm --filter frontend lint",
    "contracts:build": "cargo build --target wasm32-unknown-unknown --release --manifest-path contracts/Cargo.toml",
    "contracts:test": "cargo test --manifest-path contracts/Cargo.toml",
    "contracts:deploy": "bash contracts/deploy.sh",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
